{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "sortImports": true,
  "sortPackageJson": true,
  "sortTailwindcss": {
    "stylesheet": "src/styles/global.css"
  },
  "ignorePatterns": [
    "dist/**",
    ".astro/**",
    ".wrangler/**",
    "worker-configuration.d.ts",
    "bun.lock",
    "**/*.mdx"
  ]
}
