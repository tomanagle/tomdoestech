---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const MONTHS = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];

const { post } = Astro.props;
const { data } = post;
const href = `/blog/${post.id}`;
const dateLabel = `${data.date.getUTCDate()} ${MONTHS[data.date.getUTCMonth()]} ${data.date.getUTCFullYear()}`;
---

<article
  class="group relative rounded-xl border border-border bg-surface p-5 transition duration-200 hover:-translate-y-0.5 hover:border-accent"
>
  <div class="flex items-baseline justify-between gap-3">
    <h3 class="text-lg font-semibold tracking-tight">
      <a href={href} class="after:absolute after:inset-0">
        {data.title}
      </a>
    </h3>
    <time
      datetime={data.date.toISOString()}
      class="shrink-0 font-mono text-sm text-faint"
    >
      {dateLabel}
    </time>
  </div>

  <p class="mt-2 text-sm text-fg">
    {data.description}
  </p>

  {
    data.tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {data.tags.map((t) => (
          <li class="rounded-full bg-surface-2 px-2.5 py-0.5 text-sm text-fg">
            {t}
          </li>
        ))}
      </ul>
    )
  }
</article>
