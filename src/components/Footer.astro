---
import { profile } from "../data/profile";

const year = new Date().getFullYear();
---

<footer
  class="border-t border-zinc-200 py-8 text-sm text-zinc-500 dark:border-zinc-800 dark:text-zinc-400"
>
  <div
    class="mx-auto flex w-full max-w-3xl flex-col items-center justify-between gap-3 px-5 sm:flex-row"
  >
    <p>© {year} {profile.name}</p>
    <ul class="flex gap-4">
      {
        profile.socials.map((social) => (
          <li>
            <a
              href={social.url}
              target="_blank"
              rel="me noopener noreferrer"
              class="transition-colors hover:text-accent-600 dark:hover:text-accent-400"
            >
              {social.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
