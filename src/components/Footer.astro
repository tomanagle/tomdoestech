---
import { profile } from "../data/profile";

const year = new Date().getFullYear();
---

<footer class="border-t border-border py-8 text-sm text-fg">
  <div
    class="mx-auto flex w-full max-w-[60rem] flex-col items-center justify-between gap-3 px-6 sm:flex-row"
  >
    <p>© {year} {profile.name}</p>
    <ul class="flex gap-4">
      {
        profile.socials.map((social) => (
          <li>
            <a
              href={social.url}
              target="_blank"
              rel="me noopener noreferrer"
              aria-label={`${social.label} (opens in new tab)`}
              class="transition-colors hover:text-accent-strong"
            >
              {social.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
