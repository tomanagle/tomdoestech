---
// A vertical step-by-step flow diagram for writeups. Dependency-free, themed,
// and accessible (real text in document order; arrows are decorative).
interface Step {
  title: string;
  body?: string;
}
interface Props {
  steps: Step[];
  caption?: string;
}
const { steps, caption } = Astro.props;
---

<figure class="not-prose my-7">
  <div class="flex flex-col">
    {
      steps.map((step, i) => (
        <div>
          <div class="rounded-xl border border-border bg-surface px-4 py-3">
            <p class="font-medium text-fg">{step.title}</p>
            {step.body && <p class="mt-1 text-sm text-faint">{step.body}</p>}
          </div>
          {i < steps.length - 1 && (
            <div
              aria-hidden="true"
              class="flex h-7 items-center justify-center text-faint"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4"
              >
                <path d="M12 5v14M19 12l-7 7-7-7" />
              </svg>
            </div>
          )}
        </div>
      ))
    }
  </div>
  {
    caption && (
      <figcaption class="mt-3 text-center text-sm text-faint">
        {caption}
      </figcaption>
    )
  }
</figure>
