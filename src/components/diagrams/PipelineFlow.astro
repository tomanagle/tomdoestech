---
// Illustrated data pipeline. Source services fan into the first stage; message
// glyphs animate into Kafka and document glyphs flow toward S3. The flow wraps
// into stacked layers (via `wrapAfter`) so it fits the page with no side
// scroll, and the final stage can render as a browser dashboard on a laptop.
// CSS/SVG only, themed, reduced-motion safe.
interface Stage {
  title: string;
  icon: string;
  badge?: string;
  note?: string;
  flow?: "message" | "document" | "data";
  laptop?: boolean;
}
interface Props {
  sources: string[];
  stages: Stage[];
  /** Number of stages (including the fan-in target) to keep on the first row. */
  wrapAfter?: number;
  caption?: string;
}
const { sources, stages, caption } = Astro.props;
const cut = Astro.props.wrapAfter ?? stages.length;
const row1 = stages.slice(0, cut);
const row2 = stages.slice(cut);
const [first, ...row1rest] = row1;

const icons: Record<string, string> = {
  api: '<rect x="2" y="3" width="20" height="6" rx="1.5"/><rect x="2" y="15" width="20" height="6" rx="1.5"/><line x1="6" y1="6" x2="6" y2="6"/><line x1="6" y1="18" x2="6" y2="18"/>',
  message:
    '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  file: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>',
  stream:
    '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  flame:
    '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.07-2.14-.22-4.05 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.15.43-2.29 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>',
  database:
    '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/>',
  sparkles:
    '<path d="M12 3 10.1 8.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3z"/>',
  snowflake:
    '<line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="2" x2="12" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/>',
};
const svg = (name: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icons[name] ?? ""}</svg>`;
---

<figure class="pipeline not-prose my-7">
  <div class="rail">
    <div class="row">
      <div class="fanin">
        {
          sources.map((source, i) => (
            <div class="src" style={`grid-row:${i + 1}`}>
              <span class="ic" set:html={svg("api")} />
              <span class="src__title">{source}</span>
            </div>
          ))
        }
        {
          sources.map((_, i) => (
            <div class="merge" style={`grid-row:${i + 1}`} aria-hidden="true">
              <span
                class="glyph"
                style={`animation-delay:${i * 0.35}s`}
                set:html={svg("message")}
              />
            </div>
          ))
        }
        <div
          class="node node--tall"
          style={`grid-row:1 / span ${sources.length}`}
        >
          <span class="ic" set:html={svg(first.icon)} />
          <span class="node__title">{first.title}</span>
          {first.badge && <span class="node__badge">{first.badge}</span>}
        </div>
      </div>

      {
        row1rest.map((stage) => (
          <>
            <div class="conn" aria-hidden="true">
              {stage.flow === "message" || stage.flow === "document" ? (
                <span
                  class="glyph"
                  set:html={svg(stage.flow === "message" ? "message" : "file")}
                />
              ) : (
                <span class="dot" />
              )}
            </div>
            <div class="node">
              <span class="ic" set:html={svg(stage.icon)} />
              <span class="node__title">{stage.title}</span>
              {stage.note && <span class="note">{stage.note}</span>}
              {stage.badge && <span class="node__badge">{stage.badge}</span>}
            </div>
          </>
        ))
      }
    </div>

    {
      row2.length > 0 && (
        <div class="turn" aria-hidden="true">
          <span class="vdot" />
          <svg
            class="turn__arrow"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M6 9l6 6 6-6" />
          </svg>
        </div>
      )
    }

    {
      row2.length > 0 && (
        <div class="row">
          {row2.map((stage, i) => (
            <>
              {i > 0 && (
                <div class="conn" aria-hidden="true">
                  {stage.flow === "message" || stage.flow === "document" ? (
                    <span
                      class="glyph"
                      set:html={svg(
                        stage.flow === "message" ? "message" : "file",
                      )}
                    />
                  ) : (
                    <span class="dot" />
                  )}
                </div>
              )}
              {stage.laptop ? (
                <div class="laptop-wrap">
                  <div class="laptop">
                    <div class="screen">
                      <div class="chrome">
                        <span class="tl" />
                        <span class="tl" />
                        <span class="tl" />
                        <span class="addr" />
                      </div>
                      <div class="dash">
                        <div class="kpis">
                          <span class="kpi" />
                          <span class="kpi" />
                          <span class="kpi" />
                        </div>
                        <div class="bars">
                          <i style="height:45%" />
                          <i style="height:70%" />
                          <i style="height:55%" />
                          <i style="height:90%" />
                          <i style="height:65%" />
                        </div>
                      </div>
                    </div>
                    <div class="base" />
                  </div>
                  <span class="laptop__title">{stage.title}</span>
                  {stage.badge && <span class="node__badge">{stage.badge}</span>}
                </div>
              ) : (
                <div class="node">
                  <span class="ic" set:html={svg(stage.icon)} />
                  <span class="node__title">{stage.title}</span>
                  {stage.note && <span class="note">{stage.note}</span>}
                  {stage.badge && <span class="node__badge">{stage.badge}</span>}
                </div>
              )}
            </>
          ))}
        </div>
      )
    }
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .rail {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  /* nodes + sources */
  .node,
  .src {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--border);
    background: var(--surface);
    border-radius: 14px;
    padding: 0.7rem 0.85rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    white-space: nowrap;
  }
  .ic {
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent-strong);
  }
  .ic :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
  }
  .node__title,
  .src__title {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--fg);
  }
  .node__badge {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent-strong);
  }
  .note {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.05rem 0.5rem;
    border-radius: 999px;
    background: var(--surface-2);
    color: var(--fg);
  }
  .node--tall {
    align-self: stretch;
    justify-content: center;
  }

  /* fan-in grid */
  .fanin {
    display: grid;
    grid-template-columns: max-content 3rem max-content;
    row-gap: 0.55rem;
    align-items: center;
  }
  .src {
    grid-column: 1;
    flex-direction: row;
    padding: 0.45rem 0.7rem;
  }
  .src .ic {
    width: 1.7rem;
    height: 1.7rem;
  }
  .src__title {
    font-size: 0.85rem;
  }

  /* connectors */
  .merge,
  .conn {
    position: relative;
    height: 2px;
    background: var(--border);
    align-self: center;
  }
  .merge {
    grid-column: 2;
  }
  .conn {
    width: 3rem;
    flex: none;
  }
  .dot,
  .glyph {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(0, -50%);
    opacity: 0;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--accent);
  }
  .glyph {
    color: var(--accent);
  }
  .glyph :global(svg) {
    width: 15px;
    height: 15px;
    display: block;
  }

  /* layer turn (down) */
  .turn {
    position: relative;
    width: 2px;
    height: 2.4rem;
    margin-top: 0.25rem;
    margin-bottom: 0.9rem;
    background: var(--border);
  }
  .turn__arrow {
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    color: var(--faint);
  }
  .vdot {
    position: absolute;
    left: 50%;
    top: 0;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--accent);
    transform: translateX(-50%);
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .dot,
    .glyph {
      animation: pipeline-flow 1.7s linear infinite;
    }
    .vdot {
      animation: pipeline-down 1.7s linear infinite;
    }
  }
  @keyframes pipeline-flow {
    0% {
      left: -4px;
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 1;
    }
    100% {
      left: calc(100% - 4px);
      opacity: 0;
    }
  }
  @keyframes pipeline-down {
    0% {
      top: -4px;
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 1;
    }
    100% {
      top: calc(100% - 4px);
      opacity: 0;
    }
  }

  /* laptop dashboard mockup */
  .laptop-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
  }
  .laptop {
    width: 180px;
  }
  .screen {
    border: 2px solid var(--border);
    border-bottom: 0;
    border-radius: 12px 12px 0 0;
    background: var(--surface);
    padding: 7px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }
  .chrome {
    display: flex;
    align-items: center;
    gap: 4px;
    padding-bottom: 6px;
  }
  .tl {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--faint);
    opacity: 0.55;
  }
  .addr {
    flex: 1;
    height: 7px;
    margin-left: 4px;
    border-radius: 999px;
    background: var(--surface-2);
  }
  .dash {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 7px;
  }
  .kpis {
    display: flex;
    gap: 5px;
    margin-bottom: 7px;
  }
  .kpi {
    flex: 1;
    height: 16px;
    border-radius: 4px;
    background: var(--surface-2);
  }
  .bars {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    height: 42px;
  }
  .bars i {
    flex: 1;
    border-radius: 3px 3px 0 0;
    background: var(--accent);
    opacity: 0.85;
  }
  .base {
    height: 9px;
    border-radius: 0 0 7px 7px;
    background: var(--surface-2);
    border: 2px solid var(--border);
    border-top: 0;
    box-shadow: 0 6px 12px -8px rgba(0, 0, 0, 0.4);
  }
  .laptop__title {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--fg);
  }

  figcaption {
    margin-top: 0.9rem;
    text-align: center;
    font-size: 0.875rem;
    color: var(--faint);
  }
</style>
