---
import { profile } from "../data/profile";
---

<ul class="flex flex-wrap gap-3">
  {
    profile.socials.map((social) => (
      <li>
        <a
          href={social.url}
          target="_blank"
          rel="me noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-zinc-200 px-3 py-1.5 text-sm transition-colors hover:border-accent-500 hover:text-accent-600 dark:border-zinc-800 dark:hover:border-accent-400 dark:hover:text-accent-400"
        >
          <span class="font-medium">{social.label}</span>
          {social.handle && (
            <span class="text-zinc-500 dark:text-zinc-400">
              {social.handle}
            </span>
          )}
        </a>
      </li>
    ))
  }
</ul>
