---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data } = project;
const href = `/projects/${project.id}`;
---

<article
  class="group relative rounded-xl border border-border bg-surface p-5 transition duration-200 hover:-translate-y-0.5 hover:border-accent"
>
  <div class="flex items-baseline justify-between gap-3">
    <div>
      <h2 class="text-lg font-semibold tracking-tight">
        <a href={href} class="after:absolute after:inset-0">
          {data.title}
        </a>
      </h2>
      {
        data.company && (
          <div class="mt-0.5 text-sm text-accent-strong">{data.company}</div>
        )
      }
    </div>
    {
      data.period && (
        <span class="shrink-0 font-mono text-sm text-faint">
          {data.period}
        </span>
      )
    }
  </div>

  <p class="mt-2 text-sm text-fg">
    {data.description}
  </p>

  {
    data.tech.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {data.tech.map((t) => (
          <li class="rounded-full bg-surface-2 px-2.5 py-0.5 text-sm text-fg">
            {t}
          </li>
        ))}
      </ul>
    )
  }
</article>
