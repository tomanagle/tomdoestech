---
import { getCollection } from "astro:content";
import type { Company } from "../data/companies";
import { profile } from "../data/profile";

// Never include drafts (set `draft: false` to publish a writeup).
const projects = await getCollection("projects", ({ data }) => !data.draft);

// Projects built for a given company, matched on the `company` field.
const projectsFor = (company: Company) =>
  projects
    .filter((project) => project.data.company === company)
    .toSorted((a, b) => a.data.order - b.data.order);
---

<ol class="relative ml-1.5 border-l border-border">
  {
    profile.workHistory.map((job) => {
      const jobProjects = projectsFor(job.company);
      return (
        <li class="relative ml-6 pb-10 last:pb-0">
          <span
            aria-hidden="true"
            class="absolute -left-[30.5px] top-1 h-3 w-3 rounded-full border-2 border-bg bg-accent"
          />

          <h3 class="font-semibold tracking-tight">{job.company}</h3>
          {job.location && (
            <p class="text-sm text-faint">{job.location}</p>
          )}

          <div class="mt-3 space-y-4">
            {job.roles.map((role) => (
              <div>
                <p class="text-sm font-medium text-fg">{role.title}</p>
                <p class="font-mono text-sm text-fg">{role.period}</p>
                {role.highlights && role.highlights.length > 0 && (
                  <ul class="mt-2 list-disc space-y-1 pl-4 text-sm text-fg marker:text-faint">
                    {role.highlights.map((highlight) => (
                      <li>{highlight}</li>
                    ))}
                  </ul>
                )}
              </div>
            ))}
          </div>

          {jobProjects.length > 0 && (
            <ul class="mt-4 flex flex-wrap items-center gap-2 text-sm">
              <li class="text-faint">Projects:</li>
              {jobProjects.map((project) => (
                <li>
                  <a
                    href={`/projects/${project.id}`}
                    class="rounded-full bg-surface-2 px-2.5 py-0.5 text-accent transition-colors hover:bg-accent-soft"
                  >
                    {project.data.title}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      );
    })
  }
</ol>
