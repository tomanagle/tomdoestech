---
import { profile } from "../data/profile";

const links = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
];

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header
  class="sticky top-0 z-10 border-b border-zinc-200 bg-white/80 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/80"
>
  <nav
    class="mx-auto flex w-full max-w-3xl items-center justify-between px-5 py-4"
  >
    <a href="/" class="font-mono text-sm font-semibold tracking-tight">
      {profile.name}
    </a>
    <ul class="flex items-center gap-5 text-sm">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
              class:list={[
                "transition-colors hover:text-accent-600 dark:hover:text-accent-400",
                isActive(link.href)
                  ? "text-accent-600 dark:text-accent-400"
                  : "text-zinc-600 dark:text-zinc-400",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
