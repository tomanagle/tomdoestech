---
import { profile } from "../data/profile";

const { pathname } = Astro.url;
const onProjects = pathname.startsWith("/projects");
---

<header class="sticky top-0 z-50 pt-4">
  <div class="container">
    <nav
      aria-label="Primary"
      class="flex items-center justify-between gap-4 rounded-full border border-border bg-surface/70 py-2 pr-2 pl-5 shadow-[0_12px_34px_-16px_rgba(0,0,0,0.4)] backdrop-blur-md"
    >
      <a
        href="/"
        class="font-display text-[0.95rem] font-semibold tracking-tight"
      >
        {profile.name}
      </a>

      <!-- Desktop links -->
      <div class="hidden items-center gap-5 text-sm sm:flex">
        <a href="/#work" class="text-faint transition-colors hover:text-fg">
          Experience
        </a>
        <a
          href="/projects"
          aria-current={onProjects ? "page" : undefined}
          class:list={[
            "transition-colors hover:text-fg",
            onProjects ? "text-fg" : "text-faint",
          ]}
        >
          Projects
        </a>
        <a href="/#personal" class="text-faint transition-colors hover:text-fg">
          Personal
        </a>
        <a
          href={`mailto:${profile.email}`}
          class="inline-flex items-center gap-1.5 rounded-full bg-accent px-3.5 py-1.5 font-medium text-accent-contrast transition-colors hover:bg-accent-strong"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="m3 7 9 6 9-6"></path>
          </svg>
          Get in touch
        </a>
      </div>

      <!-- Mobile toggle -->
      <button
        id="navToggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobileNav"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-fg transition-colors hover:bg-surface-2 sm:hidden"
      >
        <svg
          class="open h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
        <svg
          class="close h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M6 6l12 12M18 6 6 18"></path>
        </svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <div
      id="mobileNav"
      hidden
      class="mt-2 flex flex-col gap-1 rounded-3xl border border-border bg-surface/95 p-2 shadow-[0_12px_34px_-16px_rgba(0,0,0,0.4)] backdrop-blur-md sm:hidden"
    >
      <a
        href="/#work"
        class="rounded-2xl px-4 py-3 text-fg transition-colors hover:bg-surface-2"
      >
        Experience
      </a>
      <a
        href="/projects"
        aria-current={onProjects ? "page" : undefined}
        class="rounded-2xl px-4 py-3 text-fg transition-colors hover:bg-surface-2"
      >
        Projects
      </a>
      <a
        href="/#personal"
        class="rounded-2xl px-4 py-3 text-fg transition-colors hover:bg-surface-2"
      >
        Personal
      </a>
      <a
        href={`mailto:${profile.email}`}
        class="mt-1 inline-flex items-center justify-center gap-1.5 rounded-2xl bg-accent px-4 py-3 font-medium text-accent-contrast transition-colors hover:bg-accent-strong"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="m3 7 9 6 9-6"></path>
        </svg>
        Get in touch
      </a>
    </div>
  </div>
</header>

<style>
  #navToggle .close {
    display: none;
  }
  #navToggle[aria-expanded="true"] .open {
    display: none;
  }
  #navToggle[aria-expanded="true"] .close {
    display: block;
  }
</style>

<script>
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("mobileNav");

  function setOpen(open: boolean) {
    if (!toggle || !menu) return;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    menu.toggleAttribute("hidden", !open);
  }

  toggle?.addEventListener("click", () => {
    setOpen(toggle.getAttribute("aria-expanded") !== "true");
  });

  // Close on link tap (covers same-page anchors), and on Escape.
  menu?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) setOpen(false);
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });
</script>
