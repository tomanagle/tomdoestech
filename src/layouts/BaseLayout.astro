---
// Self-hosted fonts (no render-blocking Google Fonts CDN / cross-origin chain).
import "@fontsource-variable/inter";
import "@fontsource-variable/inter-tight";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { profile } from "../data/profile";

interface Props {
  title?: string;
  description?: string;
  /** Path to an OG image under /public, or an absolute URL. Defaults to the site card. */
  ogImage?: string;
  /** "website" (default) or "article" for project writeups. */
  ogType?: "website" | "article";
  /** ISO date string for article:published_time on writeups. */
  publishedTime?: string;
}

const {
  title,
  description = profile.bio.tagline,
  ogImage = "/og.png",
  ogType = "website",
  publishedTime,
} = Astro.props;

const site = Astro.site ?? Astro.url;
const pageTitle = title ? `${title} - ${profile.name}` : profile.name;
const canonical = new URL(Astro.url.pathname, site);
const ogImageUrl = new URL(ogImage, site);
const ogImageAlt = title
  ? `${title} - ${profile.name}`
  : `${profile.name}, Senior Software Engineer`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    {/* Apply the saved "pause animations" preference before first paint. */}
    <script is:inline>
      try {
        if (localStorage.getItem("motion") === "off")
          document.documentElement.dataset.motion = "off";
      } catch (e) {}
    </script>

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <link rel="canonical" href={canonical} />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fbfbfa"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#0b1120"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={ogImageAlt} />
    {
      ogType === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === "article" && (
        <meta property="article:author" content={profile.name} />
      )
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:border focus:border-border focus:bg-surface focus:px-4 focus:py-2 focus:text-fg"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="w-full flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
