---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "../../components/Prose.astro";
import Callout from "../../components/mdx/Callout.astro";
import Image from "../../components/mdx/Image.astro";

export const getStaticPaths = (async () => {
  // Never include drafts - they get no published page.
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const MONTHS = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const dateLabel = `${data.date.getUTCDate()} ${MONTHS[data.date.getUTCMonth()]} ${data.date.getUTCFullYear()}`;
---

<BaseLayout
  title={data.title}
  description={data.description}
  ogType="article"
  publishedTime={data.date.toISOString()}
>
  <div class="container">
    <article class="py-10">
      <a
        href="/blog"
        class="text-sm text-fg transition-colors hover:text-accent-strong"
      >
        ← All posts
      </a>

      <header class="mt-4 space-y-3 border-b border-border pb-6 mb-6">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          {data.title}
        </h1>
        <p class="text-lg text-fg">
          {data.description}
        </p>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-fg">
          <time datetime={data.date.toISOString()} class="font-mono">
            {dateLabel}
          </time>
          {data.tags.map((t) => (
            <span class="text-accent-strong">#{t}</span>
          ))}
        </div>
      </header>

      <Prose>
        <Content components={{ Callout, img: Image }} />
      </Prose>
    </article>
  </div>
</BaseLayout>
