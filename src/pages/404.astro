---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="404 — page not found.">
  <section class="space-y-4 py-12 text-center">
    <p class="font-mono text-5xl font-bold text-accent-600 dark:text-accent-400">
      404
    </p>
    <h1 class="text-2xl font-semibold tracking-tight">Page not found</h1>
    <p class="text-zinc-600 dark:text-zinc-400">
      That page doesn't exist or has moved.
    </p>
    <p>
      <a
        href="/"
        class="text-accent-600 hover:underline dark:text-accent-400"
      >
        ← Back home
      </a>
    </p>
  </section>
</BaseLayout>
