---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="Page not found.">
  <div class="container">
    <section class="space-y-4 py-24 text-center">
    <p class="font-mono text-5xl font-bold text-accent">404</p>
    <h1 class="text-2xl font-semibold tracking-tight">Page not found</h1>
    <p class="text-fg">That page doesn't exist or has moved.</p>
    <p>
      <a href="/" class="text-accent hover:underline">← Back home</a>
    </p>
    </section>
  </div>
</BaseLayout>
