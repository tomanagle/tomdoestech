---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "../../components/Prose.astro";
import Callout from "../../components/mdx/Callout.astro";
import Image from "../../components/mdx/Image.astro";
import MotionToggle from "../../components/MotionToggle.astro";

export const getStaticPaths = (async () => {
  // Never include drafts - they get no published page.
  const projects = await getCollection(
    "projects",
    ({ data }) => !data.draft,
  );
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
---

<BaseLayout title={data.title} description={data.description}>
  <article class="py-10">
    <a
      href="/projects"
      class="text-sm text-fg transition-colors hover:text-accent-strong"
    >
      ← All projects
    </a>

    <header class="mt-4 space-y-3 border-b border-border pb-6 mb-6">
      <div class="flex items-start justify-between gap-4">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          {data.title}
        </h1>
        <MotionToggle />
      </div>
      <p class="text-lg text-fg">
        {data.description}
      </p>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-fg">
        {data.role && <span>{data.role}</span>}
        {data.company && <span class="text-accent-strong">{data.company}</span>}
        {data.period && <span class="font-mono">{data.period}</span>}
      </div>

      {
        data.tech.length > 0 && (
          <ul class="flex flex-wrap gap-2">
            {data.tech.map((t) => (
              <li class="rounded-full bg-surface-2 px-2.5 py-0.5 text-sm text-fg">
                {t}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <Prose>
      <Content components={{ Callout, img: Image }} />
    </Prose>
  </article>
</BaseLayout>
