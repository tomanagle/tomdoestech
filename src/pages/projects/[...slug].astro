---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "../../components/Prose.astro";
import Callout from "../../components/mdx/Callout.astro";

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const externalLinks = [
  data.links?.live && { label: "Live", url: data.links.live },
  data.links?.repo && { label: "Source", url: data.links.repo },
].filter(Boolean) as { label: string; url: string }[];
---

<BaseLayout title={data.title} description={data.description}>
  <article>
    <a
      href="/projects"
      class="text-sm text-zinc-500 transition-colors hover:text-accent-600 dark:text-zinc-400 dark:hover:text-accent-400"
    >
      ← All projects
    </a>

    <header class="mt-4 space-y-3 border-b border-zinc-200 pb-6 dark:border-zinc-800">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
        {data.title}
      </h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-400">
        {data.description}
      </p>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-zinc-500 dark:text-zinc-400">
        {data.role && <span>{data.role}</span>}
        {data.period && <span class="font-mono">{data.period}</span>}
      </div>

      {
        data.tech.length > 0 && (
          <ul class="flex flex-wrap gap-2">
            {data.tech.map((t) => (
              <li class="rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
                {t}
              </li>
            ))}
          </ul>
        )
      }

      {
        externalLinks.length > 0 && (
          <ul class="flex flex-wrap gap-4 text-sm">
            {externalLinks.map((link) => (
              <li>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent-600 hover:underline dark:text-accent-400"
                >
                  {link.label} ↗
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <Prose>
      <Content components={{ Callout }} />
    </Prose>
  </article>
</BaseLayout>
