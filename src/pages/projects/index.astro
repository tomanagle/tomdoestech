---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";

// Hide drafts in production; show them while developing.
const projects = await getCollection("projects", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);

// Featured first, then by ascending `order`, then alphabetically.
const sorted = projects.toSorted((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  if (a.data.order !== b.data.order) return a.data.order - b.data.order;
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout
  title="Projects"
  description="Writeups of projects I've worked on."
>
  <section class="space-y-8">
    <header class="space-y-2">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Projects</h1>
      <p class="text-zinc-600 dark:text-zinc-400">
        Writeups of things I've built — the context, how I implemented them,
        and what I learned.
      </p>
    </header>

    {
      sorted.length === 0 ? (
        <p class="text-zinc-500 dark:text-zinc-400">
          No projects published yet — check back soon.
        </p>
      ) : (
        <div class="grid gap-4">
          {sorted.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
