---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import WorkHistory from "../components/WorkHistory.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { profile } from "../data/profile";

// Never include drafts (set `draft: false` to publish a writeup).
const published = await getCollection("projects", ({ data }) => !data.draft);
const featured = published
  .filter((p) => p.data.featured)
  .toSorted((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

// Person structured data - helps search engines connect the profile + socials.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: "Senior Software Engineer",
  email: `mailto:${profile.email}`,
  url: (Astro.site ?? Astro.url).toString(),
  sameAs: profile.socials.map((s) => s.url),
};
---

<BaseLayout>
  <script
    type="application/ld+json"
    slot="head"
    is:inline
    set:html={JSON.stringify(personLd)}
  />

  <!-- Hero -->
  <section class="hero relative isolate pt-10 pb-14">
    <div class="terminal">
      <div class="terminal__bar" aria-hidden="true">
        <span class="dot dot--r"></span>
        <span class="dot dot--y"></span>
        <span class="dot dot--g"></span>
        <span class="terminal__title">tom@tomdoes.tech ~</span>
      </div>
      <div class="terminal__body">
        <h1
          class="hero-name text-3xl font-bold tracking-tight sm:text-4xl"
          aria-label={profile.name}
        >
          <span class="prompt" aria-hidden="true">&gt;</span><span
            class="typed">{profile.name}</span
          ><span class="caret" aria-hidden="true"></span>
        </h1>
        <p class="term-line term-role">
          Senior Software Engineer · Sunshine Coast, QLD
        </p>
        <p class="term-line term-bio">{profile.bio.intro}</p>
      </div>
    </div>

    <div class="mt-7 flex flex-wrap items-center gap-2.5">
      <SocialLinks />
      <a
        href="/Tom%20Nagle%20Resume.pdf"
        download="Tom-Nagle-Resume.pdf"
        class="inline-flex items-center gap-2 rounded-full bg-accent px-3.5 py-2 text-sm font-medium text-accent-contrast transition-colors hover:bg-accent-strong"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Download resume
      </a>
    </div>

    <div class="mt-11 grid gap-3.5">
      {
        profile.techStack.map((group) => (
          <div class="grid items-start gap-x-5 gap-y-1.5 sm:grid-cols-[8rem_1fr]">
            <span class="font-mono text-sm tracking-[0.1em] text-faint uppercase sm:pt-1.5">
              {group.category}
            </span>
            <div class="flex flex-wrap gap-2">
              {group.items.map((tech) => (
                <a
                  href={`/projects?tech=${encodeURIComponent(tech)}`}
                  class="rounded-lg border border-transparent bg-surface-2 px-2.5 py-1 text-sm transition-colors hover:border-accent hover:text-accent-strong"
                >
                  <span class="sr-only">View projects using </span>{tech}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Experience -->
  <section id="work" class="border-t border-border py-16">
    <h2 class="mb-7 font-mono text-sm tracking-[0.14em] text-faint uppercase">
      Experience
    </h2>
    <WorkHistory />
  </section>

  <!-- Selected projects -->
  {
    featured.length > 0 && (
      <section class="border-t border-border py-16">
        <div class="mb-7 flex items-baseline justify-between gap-4">
          <h2 class="font-mono text-sm tracking-[0.14em] text-faint uppercase">
            Selected projects
          </h2>
          <a href="/projects" class="text-sm text-accent hover:underline">
            All projects →
          </a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {featured.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .hero::before {
    content: "";
    position: absolute;
    inset: -30% -15% auto -15%;
    height: 420px;
    z-index: -1;
    background: radial-gradient(
      55% 60% at 25% 0%,
      color-mix(in srgb, var(--accent) 18%, transparent),
      transparent 72%
    );
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero > * {
      animation: rise 0.5s ease both;
    }
    .hero > *:nth-child(2) {
      animation-delay: 0.05s;
    }
    .hero > *:nth-child(3) {
      animation-delay: 0.1s;
    }
    .hero > *:nth-child(4) {
      animation-delay: 0.15s;
    }
    .hero > *:nth-child(5) {
      animation-delay: 0.2s;
    }
  }
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* Terminal window around the hero intro. */
  .terminal {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    overflow: hidden;
    box-shadow: 0 16px 40px -28px rgba(0, 0, 0, 0.5);
    font-family: var(--font-mono);
  }
  .terminal__bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.85rem;
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
  }
  .terminal__bar .dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
  }
  .dot--r {
    background: #ff5f57;
  }
  .dot--y {
    background: #febc2e;
  }
  .dot--g {
    background: #28c840;
  }
  .terminal__title {
    margin-left: 0.5rem;
    font-size: 0.8rem;
    color: var(--faint);
  }
  .terminal__body {
    padding: 1.15rem 1.3rem 1.4rem;
  }
  .term-line {
    font-family: var(--font-mono);
    line-height: 1.65;
    margin-top: 0.55rem;
  }
  .term-role {
    color: var(--faint);
    font-size: 0.95rem;
  }
  .term-bio {
    color: var(--fg);
    font-size: 0.95rem;
    max-width: 36rem;
  }

  /* Typewriter caret for the hero name. */
  .hero-name {
    font-family: var(--font-mono);
    /* keep the line height stable while the name types in */
    min-height: 1.1em;
  }
  .hero-name .prompt {
    color: var(--accent);
    margin-right: 0.45rem;
  }
  .hero-name .caret {
    display: inline-block;
    width: 0.5em;
    height: 0.9em;
    margin-left: 0.08em;
    vertical-align: -0.08em;
    border-radius: 2px;
    background: var(--accent);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-name .caret {
      animation: caret-blink 1.05s steps(1) infinite;
    }
  }
  @keyframes caret-blink {
    50% {
      opacity: 0;
    }
  }
  /* No caret when motion is reduced or the user paused animations. */
  @media (prefers-reduced-motion: reduce) {
    .hero-name .caret {
      display: none;
    }
  }
  :global(html[data-motion="off"]) .hero-name .caret {
    display: none;
  }
</style>

<script>
  const typed = document.querySelector<HTMLElement>(".hero-name .typed");
  if (typed) {
    const reduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const paused = document.documentElement.dataset.motion === "off";
    const full = typed.textContent ?? "";
    if (full && !reduced && !paused) {
      typed.textContent = "";
      let i = 0;
      const step = () => {
        typed.textContent = full.slice(0, ++i);
        if (i < full.length) window.setTimeout(step, 85);
      };
      window.setTimeout(step, 280);
    }
  }
</script>
